{
  "manifest_version": 3,
  "name": "JustHot",
  "version": "5.0.1",
  "description": "Mutes ad breaks on Hotstar live matches. Fast-forwards ads on Prime Video. Each platform toggled independently.",
  "permissions": ["storage", "webRequest", "tabs"],
  "host_permissions": [
    "*://*.hotstar.com/*",
    "*://*.jiohotstar.com/*",
    "*://bifrost-api.hotstar.com/*",
    "*://*.primevideo.com/*",
    "*://*.amazon.com/*",
    "*://*.amazon.in/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "JustHot — ad control",
    "default_icon": {
      "16": "icons/icon16-gray.png",
      "32": "icons/icon32-gray.png",
      "48": "icons/icon48-gray.png",
      "128": "icons/icon128-gray.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png",
    "256": "icons/icon256.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.hotstar.com/*",
        "*://*.jiohotstar.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://*.primevideo.com/*",
        "*://*.amazon.com/gp/video/*",
        "*://*.amazon.in/gp/video/*"
      ],
      "js": ["prime.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
